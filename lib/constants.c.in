#if HAVE_CONFIG_H
#include <config.h>
#endif

#cmakedefine VOLK_STATIC_DISPATCH

#ifndef VOLK_STATIC_DISPATCH
#include <stdlib.h>
#endif
#include <volk/constants.h>

const char*
volk_prefix()
{
#ifndef VOLK_STATIC_DISPATCH
  const char *prefix = getenv("VOLK_PREFIX");
  if (prefix != NULL) return prefix;
#endif
  return "@prefix@";
}

const char*
volk_version()
{
  return "@VERSION@";
}

const char*
volk_c_compiler()
{
  return "@cmake_c_compiler_version@";
}

const char*
volk_compiler_flags()
{
  return "@COMPILER_INFO@";
}

const char*
volk_available_machines()
{
  return "@available_machines@";
}
